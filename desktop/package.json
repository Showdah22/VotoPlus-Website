{
  "name": "voto-plus-desktop",
  "private": true,
  "version": "0.6.5",
  "description": "Voto+ Desktop — app companion per Windows e macOS. Studia con Voto+ dal computer.",
  "author": "Voto+ Team",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/Showdah22/VotoPlus-Website.git"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && electron-builder",
    "build:win": "tsc --noEmit && vite build && electron-builder --win",
    "build:mac": "tsc --noEmit && vite build && electron-builder --mac",
    "lint": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.1",
    "lucide-react": "^0.460.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^32.2.5",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "app.voto-plus.desktop",
    "productName": "Voto+ Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "VotoPlus-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.education",
      "artifactName": "VotoPlus-${version}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Voto+ usa il microfono per la modalità di interrogazione orale con il professore AI.",
        "NSCameraUsageDescription": "Voto+ può usare la fotocamera per scansionare documenti da studiare.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Showdah22",
        "repo": "VotoPlus-Website",
        "releaseType": "release",
        "publishAutoUpdate": true
      }
    ]
  }
}
