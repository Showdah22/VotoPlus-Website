---
// Voto+ website · Footer condiviso (link legali + store + social)
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <div class="brand">
        <img src="/favicon.png" alt="Voto+" width="32" height="32" />
      </div>
      <p class="tagline">
        L'app AI per studenti italiani delle scuole superiori.<br />
        Organizza lo studio, migliora i voti, prepara le interrogazioni.
      </p>
    </div>

    <div class="footer-col">
      <h4>Prodotto</h4>
      <ul>
        <li><a href="/overview">Overview</a></li>
        <li><a href="/prezzi">Prezzi</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Scarica</h4>
      <ul>
        <li><a href="https://apps.apple.com/it/app/voto/id6787898039" target="_blank" rel="noopener">App Store</a></li>
        <li><a href="https://play.google.com/store/apps/details?id=app.voto_plus" target="_blank" rel="noopener">Google Play</a></li>
        <li><a href="/download">Voto+ Desktop</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h4>Legale</h4>
      <ul>
        <li><a href="/privacy.html">Privacy</a></li>
        <li><a href="/terms.html">Termini</a></li>
        <li><a href="/support.html">Supporto</a></li>
        <li><a href="/delete-account.html">Elimina account</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom container">
    <span>© {year} Voto+ · Tutti i diritti riservati</span>
    <span>Fatta con 💜 in Italia</span>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(180deg, var(--bg) 0%, #050508 100%);
    border-top: 1px solid var(--border);
    padding-top: 60px;
    margin-top: 80px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 40px;
  }
  .footer-brand .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 900;
    font-size: 20px;
    margin-bottom: 12px;
  }
  .brand-text {
    background: linear-gradient(135deg, var(--purple), var(--pink));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .tagline {
    color: var(--text-sub);
    font-size: 14px;
    line-height: 1.6;
    max-width: 320px;
  }
  .footer-col h4 {
    font-size: 13px;
    font-weight: 900;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--purple);
    margin-bottom: 14px;
  }
  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-col a {
    color: var(--text-sub);
    font-size: 14px;
    transition: color 0.15s ease;
  }
  .footer-col a:hover {
    color: var(--text-primary);
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 32px 24px;
    margin-top: 40px;
    border-top: 1px solid var(--border);
    color: var(--text-muted);
    font-size: 13px;
  }

  @media (max-width: 800px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    .footer-brand {
      grid-column: 1 / -1;
    }
    .footer-bottom {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }
</style>
