---
// Voto+ website · /faq
//
// Pagina FAQ pubblica con accordion espandibile + JSON-LD FAQPage per rich
// snippet Google. Contenuto basato sul prodotto reale (funzionalità, prezzi,
// privacy, compatibilità, account) — nessun contenuto marketing gonfiato.
//
// I singoli <details> sono nativi HTML: accessibili, zero JS, funzionano
// anche senza JavaScript.
import BaseLayout from "@/layouts/BaseLayout.astro";

interface FaqItem {
  q: string;
  a: string;
}

interface FaqCategory {
  id: string;
  emoji: string;
  label: string;
  items: FaqItem[];
}

const categories: FaqCategory[] = [
  {
    id: "come-funziona",
    emoji: "🚀",
    label: "Come funziona",
    items: [
      {
        q: "Cos'è Voto+ in una frase?",
        a: "Voto+ è l'app AI pensata per gli studenti italiani delle superiori: gestisci voti e materie, generi riassunti e quiz dai tuoi materiali di studio e ti prepari alle interrogazioni parlando con un professore virtuale.",
      },
      {
        q: "Su quali dispositivi funziona?",
        a: "Voto+ è disponibile su iPhone e iPad (dallo store di Apple), su smartphone e tablet Android (dal Play Store) e come app desktop nativa per Windows e macOS. Tutti i tuoi dati vengono sincronizzati automaticamente tra i dispositivi.",
      },
      {
        q: "Devo caricare i miei libri o le mie dispense?",
        a: "Non è obbligatorio, ma serve per ottenere il massimo. Puoi scansionare pagine, importare PDF o incollare testi: Voto+ genera riassunti, quiz e interrogazioni basandosi sui tuoi materiali. Se preferisci, puoi anche chiedere direttamente su un argomento senza allegare nulla.",
      },
      {
        q: "L'AI fa i compiti al posto mio?",
        a: "No, e per scelta. Voto+ ti aiuta a organizzare lo studio, memorizzare, ripassare e verificare quello che sai — non consegna risposte a temi o problemi. È uno strumento per capire meglio, non per barare.",
      },
      {
        q: "Come funziona l'interrogazione con la voce?",
        a: "Scegli l'argomento e premi Inizia. Un professore virtuale con voce naturale italiana ti fa domande, ascolta le tue risposte in tempo reale, ti dà un voto motivato e ti spiega dove puoi migliorare. Puoi impostare la difficoltà (base, intermedio o livello Maturità).",
      },
    ],
  },
  {
    id: "abbonamenti",
    emoji: "💳",
    label: "Abbonamenti & Prezzi",
    items: [
      {
        q: "Voto+ è gratis?",
        a: "Sì: puoi usare Voto+ gratuitamente per gestire voti, calendario verifiche e riassunti/quiz con un limite mensile. Le funzioni avanzate come interrogazioni vocali illimitate, matematica passo passo illimitata e Radar Maturità sono nel piano Premium.",
      },
      {
        q: "C'è una prova gratuita del Premium?",
        a: "Sì. Il primo abbonamento Premium include 7 giorni di prova gratuita. Puoi cancellare in qualsiasi momento prima della fine della prova senza addebiti.",
      },
      {
        q: "Come cancello l'abbonamento?",
        a: "L'abbonamento si gestisce direttamente dallo store da cui l'hai attivato (Apple ID, Google Play o Stripe se hai attivato da web). Trovi tutti i passaggi nella pagina Impostazioni → Abbonamento dell'app.",
      },
      {
        q: "Esiste un piano famiglia?",
        a: "Sì. Il piano Famiglia copre fino a 3 account personali distinti (genitori + figli o più fratelli): ogni membro ha i propri voti, i propri riassunti e la propria privacy, ma un unico abbonamento.",
      },
      {
        q: "Il prezzo cambia se rinnovo l'anno prossimo?",
        a: "No. Se sei già abbonato manterrai il prezzo attuale finché mantieni attivo il rinnovo. Eventuali aumenti si applicano solo ai nuovi abbonati.",
      },
    ],
  },
  {
    id: "privacy",
    emoji: "🔒",
    label: "Privacy & Dati",
    items: [
      {
        q: "I miei dati vengono usati per addestrare modelli AI?",
        a: "No. I tuoi materiali, i tuoi voti e le tue conversazioni con Voto+ NON vengono usati per addestrare modelli AI di terze parti. I contenuti restano tuoi.",
      },
      {
        q: "Dove sono conservati i miei dati?",
        a: "I tuoi dati sono conservati in server cloud gestiti in modo conforme al GDPR europeo. Le comunicazioni sono cifrate e l'accesso ai dati è limitato al team che gestisce il servizio.",
      },
      {
        q: "Come posso eliminare il mio account?",
        a: "Puoi eliminare il tuo account in qualsiasi momento dall'app (Impostazioni → Account → Elimina account) o dalla pagina dedicata. L'eliminazione è irreversibile e cancella tutti i dati associati entro 30 giorni.",
      },
      {
        q: "I miei genitori possono vedere quello che studio?",
        a: "Solo se lo decidi tu. Ogni account Voto+ è personale: anche nel piano Famiglia i voti, i riassunti e le interrogazioni di un membro non sono visibili agli altri.",
      },
    ],
  },
  {
    id: "compatibilita",
    emoji: "💻",
    label: "Compatibilità",
    items: [
      {
        q: "Su quale versione di iOS funziona?",
        a: "Voto+ richiede iOS 15 o superiore su iPhone e iPad. Se hai un dispositivo più vecchio ti consigliamo di aggiornare iOS quando possibile per accedere alle ultime funzioni.",
      },
      {
        q: "E per Android?",
        a: "Voto+ funziona su Android 8 (Oreo) o superiore. È testato su tutti i principali produttori (Samsung, Xiaomi, Google, Motorola, ecc.).",
      },
      {
        q: "L'app desktop richiede installazione?",
        a: "Sì, ma è leggerissima: pochi MB e installazione in un click. Scaricabile dalla pagina Download per Windows e macOS. Ti basta lo stesso account che usi su mobile per ritrovare i tuoi dati.",
      },
      {
        q: "Serve una connessione internet?",
        a: "Sì, per le funzioni AI (riassunti, quiz, interrogazioni) è necessaria una connessione. Alcune funzioni di base come visualizzare voti già registrati funzionano anche offline con sincronizzazione al ritorno online.",
      },
    ],
  },
  {
    id: "account",
    emoji: "👤",
    label: "Account e supporto",
    items: [
      {
        q: "Ho dimenticato la password. Come faccio?",
        a: "Dalla schermata di login tocca 'Password dimenticata': riceverai un'email con un link per impostare una nuova password. Se non arriva controlla lo spam o scrivici a support@votoplus.it.",
      },
      {
        q: "Posso usare Voto+ con lo stesso account su più dispositivi?",
        a: "Sì, e senza limiti. Effettui il login con la stessa email/password (o Apple/Google) e ritrovi voti, materie e riassunti sincronizzati.",
      },
      {
        q: "Come contatto il supporto?",
        a: "Scrivici a support@votoplus.it oppure dalla pagina Supporto del sito. Rispondiamo entro 1 giorno lavorativo. Gli utenti Premium hanno priorità.",
      },
      {
        q: "Voto+ è una scuola / rilascia certificazioni?",
        a: "No. Voto+ è uno strumento di studio: non rilascia titoli, certificati o valutazioni ufficiali. I voti registrati sono solo per la tua gestione personale.",
      },
    ],
  },
];

const allItems = categories.flatMap((c) => c.items);
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: allItems.map((it) => ({
    "@type": "Question",
    name: it.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: it.a,
    },
  })),
};
---

<BaseLayout
  title="FAQ · Domande frequenti su Voto+"
  description="Risposte alle domande più frequenti su Voto+: come funziona, quanto costa, privacy dei dati, compatibilità e supporto. Tutto quello che serve sapere prima di iniziare."
>
  <!-- JSON-LD FAQPage per rich snippet Google -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)}></script>

  <!-- HERO -->
  <section class="faq-hero">
    <div class="container" style="max-width:780px; text-align:center; margin: 0 auto;">
      <span class="eyebrow">FAQ</span>
      <h1 class="hero-title">Le risposte alle <span class="gradient-text">domande frequenti</span></h1>
      <p class="hero-lead">
        Come funziona Voto+, quanto costa, dove sono i tuoi dati e cosa succede se cambi dispositivo.
        Tutto in un unico posto.
      </p>
    </div>
  </section>

  <!-- CATEGORY NAV -->
  <section class="faq-nav-wrap">
    <div class="container">
      <nav class="faq-nav" aria-label="Categorie FAQ">
        {categories.map((c) => (
          <a href={`#${c.id}`} class="faq-nav-link">
            <span class="faq-nav-emoji">{c.emoji}</span>
            <span>{c.label}</span>
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- FAQ CATEGORIES -->
  <section class="section">
    <div class="container faq-container">
      {categories.map((cat) => (
        <div class="faq-category" id={cat.id}>
          <h2 class="faq-cat-title">
            <span class="faq-cat-emoji">{cat.emoji}</span>
            {cat.label}
          </h2>
          <div class="faq-list">
            {cat.items.map((item) => (
              <details class="faq-item">
                <summary class="faq-summary">
                  <span class="faq-q">{item.q}</span>
                  <span class="faq-chev" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </span>
                </summary>
                <div class="faq-a">{item.a}</div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="section faq-cta">
    <div class="container faq-cta-inner">
      <h2 class="faq-cta-title">Non hai trovato la risposta?</h2>
      <p class="faq-cta-lead">
        Scrivici direttamente: rispondiamo entro un giorno lavorativo e le richieste più frequenti finiscono qui.
      </p>
      <div class="faq-cta-row">
        <a class="btn btn-primary" href="mailto:support@votoplus.it?subject=Domanda%20su%20Voto%2B">
          ✉️ Contatta il supporto
        </a>
        <a class="btn btn-ghost" href="/overview">Vedi le funzioni</a>
      </div>
    </div>
  </section>

  <style>
    .faq-hero {
      padding: 100px 24px 40px;
      background:
        radial-gradient(ellipse at top, rgba(168, 85, 247, 0.16), transparent 55%),
        radial-gradient(ellipse at bottom, rgba(6, 182, 212, 0.08), transparent 60%);
    }
    .hero-title {
      font-size: clamp(34px, 5vw, 56px);
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -1.5px;
      margin-bottom: 20px;
    }
    .hero-lead {
      color: var(--text-sub);
      font-size: 18px;
      max-width: 620px;
      margin: 0 auto;
    }

    .faq-nav-wrap {
      position: sticky;
      top: 64px;
      z-index: 20;
      background: rgba(10, 10, 15, 0.9);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      padding: 12px 0;
    }
    .faq-nav {
      display: flex;
      gap: 8px;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .faq-nav::-webkit-scrollbar { display: none; }
    .faq-nav-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 14px;
      background: var(--bg-glass);
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--text-sub);
      font-size: 13.5px;
      font-weight: 700;
      white-space: nowrap;
      transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
    }
    .faq-nav-link:hover {
      color: var(--text-primary);
      border-color: rgba(168, 85, 247, 0.4);
      background: rgba(168, 85, 247, 0.1);
    }
    .faq-nav-emoji { font-size: 15px; }

    .faq-container { max-width: 900px; }
    .faq-category { margin-bottom: 56px; scroll-margin-top: 130px; }
    .faq-cat-title {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 26px;
      font-weight: 900;
      letter-spacing: -0.5px;
      margin-bottom: 20px;
    }
    .faq-cat-emoji { font-size: 30px; }
    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .faq-item {
      background: var(--bg-glass);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-md);
      overflow: hidden;
      transition: border-color 0.15s ease, background 0.15s ease;
    }
    .faq-item[open] {
      border-color: rgba(168, 85, 247, 0.35);
      background: rgba(168, 85, 247, 0.05);
    }
    .faq-summary {
      list-style: none;
      cursor: pointer;
      padding: 18px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      font-weight: 700;
      color: var(--text-primary);
    }
    .faq-summary::-webkit-details-marker { display: none; }
    .faq-q {
      font-size: 16px;
      line-height: 1.4;
    }
    .faq-chev {
      color: var(--text-sub);
      transition: transform 0.2s ease;
      flex-shrink: 0;
    }
    .faq-item[open] .faq-chev {
      transform: rotate(180deg);
      color: var(--purple);
    }
    .faq-a {
      padding: 0 20px 20px;
      color: var(--text-sub);
      font-size: 15.5px;
      line-height: 1.65;
    }

    .faq-cta {
      padding: 60px 24px 80px;
    }
    .faq-cta-inner {
      max-width: 720px;
      margin: 0 auto;
      text-align: center;
      padding: 44px 32px;
      background: linear-gradient(135deg, rgba(6, 182, 212, 0.12), rgba(168, 85, 247, 0.1));
      border: 1px solid rgba(6, 182, 212, 0.28);
      border-radius: var(--radius-xl);
    }
    .faq-cta-title {
      font-size: clamp(24px, 3vw, 32px);
      font-weight: 900;
      letter-spacing: -0.5px;
      margin-bottom: 12px;
    }
    .faq-cta-lead {
      color: var(--text-sub);
      font-size: 16px;
      margin-bottom: 24px;
    }
    .faq-cta-row {
      display: inline-flex;
      gap: 12px;
      flex-wrap: wrap;
      justify-content: center;
    }
  </style>
</BaseLayout>
