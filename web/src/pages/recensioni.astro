---
// Voto+ website · /recensioni
//
// Pagina pubblica delle recensioni. Struttura:
//   1. HERO con eyebrow + titolo + lead
//   2. Statistiche aggregate (count + rating) — dentro il React island
//   3. Filtri per tipo di scuola — dentro il React island
//   4. Grid di card recensione con stelle, testo, autore
//   5. Sezione "Lascia la tua recensione" con form (React island, honeypot,
//      moderazione manuale)
//
// Il caricamento delle recensioni è client-side così una nuova approvazione
// dell'admin appare senza bisogno di rebuild del sito.
import BaseLayout from "@/layouts/BaseLayout.astro";
import TestimonialsPage from "@/components/TestimonialsPage";
---

<BaseLayout
  title="Recensioni · Cosa dicono di Voto+"
  description="Recensioni verificate di studenti, universitari e genitori che usano Voto+ per studiare meglio, gestire i voti e prepararsi alle interrogazioni. Lascia anche tu la tua."
>
  <!-- HERO -->
  <section class="tst-hero">
    <div class="container hero-inner">
      <span class="eyebrow">Recensioni</span>
      <h1 class="hero-title">
        Le storie di chi usa <span class="gradient-text">Voto+</span> ogni giorno
      </h1>
      <p class="hero-lead">
        Recensioni reali di studenti delle superiori, universitari e genitori. Ogni recensione
        è moderata a mano prima della pubblicazione — niente bot, niente fake review.
      </p>
    </div>
  </section>

  <!-- LISTA + FORM (React island) -->
  <section class="section tst-list-section">
    <div class="container">
      <TestimonialsPage client:only="react" />
    </div>
  </section>

  <!-- FALLBACK NO-JS -->
  <noscript>
    <div class="container" style="max-width: 720px; margin: 40px auto; padding: 20px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; text-align: center; color: #a1a1aa;">
      <p style="margin-bottom: 8px;"><strong style="color:#fff;">JavaScript disabilitato</strong></p>
      <p>Le recensioni di Voto+ vengono caricate dinamicamente. Abilita JavaScript per vederle e per lasciarne una tua.</p>
    </div>
  </noscript>

  <style>
    .tst-hero {
      padding: 100px 24px 40px;
      text-align: center;
      background:
        radial-gradient(ellipse at top, rgba(168, 85, 247, 0.18), transparent 55%),
        radial-gradient(ellipse at bottom, rgba(245, 158, 11, 0.08), transparent 60%);
    }
    .hero-inner { max-width: 800px; margin: 0 auto; }
    .hero-title {
      font-size: clamp(34px, 5vw, 56px);
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -1.5px;
      margin-bottom: 20px;
    }
    .hero-lead {
      color: var(--text-sub);
      font-size: 18px;
      max-width: 640px;
      margin: 0 auto;
    }
    .tst-list-section { padding-top: 40px; padding-bottom: 100px; }
  </style>

  <!-- Spinner keyframes (usato dal React island) -->
  <style is:global>
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</BaseLayout>
