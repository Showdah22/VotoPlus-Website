---
import BaseLayout from "@/layouts/BaseLayout.astro";
import DesktopDownloadButton from "@/components/DesktopDownloadButton.tsx";
import Showcase from "@/components/Showcase.astro";

// Fetch build-time dell'ultima release GitHub. La pagina renderizzata
// contiene già i link diretti agli installer, così funziona anche senza
// JavaScript e senza fetch runtime. Il React island fa poi il re-fetch
// per catturare eventuali release più recenti pubblicate dopo il build.
let initialRelease: any = null;
try {
  const res = await fetch("https://api.github.com/repos/Showdah22/VotoPlus-Website/releases?per_page=10", {
    headers: { Accept: "application/vnd.github+json" },
  });
  if (res.ok) {
    const list = await res.json();
    initialRelease = list.find((r: any) => (r.assets || []).length > 2) || list[0] || null;
  }
} catch (e) {
  console.warn("[download] Build-time GitHub fetch failed");
}
---

<BaseLayout
  title="Scarica Voto+ Desktop per Windows e macOS"
  description="Scarica gratuitamente Voto+ Desktop per Windows e macOS. L'app companion per studiare sul PC con tutte le funzioni della versione mobile: interrogazioni AI, riassunti, matematica passo passo e Radar Maturità."
>
  <section class="desktop-hero">
    <div class="container" style="text-align:center; max-width: 720px;">
      <span class="eyebrow">Voto+ Desktop</span>
      <h1 class="hero-title">Studia dal <span class="gradient-text">tuo computer</span></h1>
      <p class="hero-lead">
        Voto+ Desktop è l'app companion per Windows e macOS. Tutte le funzioni della versione mobile ottimizzate per schermo grande, tastiera e mouse.
      </p>

      <DesktopDownloadButton initialRelease={initialRelease} client:load />
    </div>
  </section>

  <Showcase />

  <section class="section">
    <div class="container">
      <div class="features-grid">
        <article class="card feature">
          <div class="feature-icon" style="--tint: var(--purple)">⌨️</div>
          <h3>Ottimizzato per tastiera</h3>
          <p>Shortcut e navigazione da tastiera per lavorare più velocemente sui compiti lunghi.</p>
        </article>
        <article class="card feature">
          <div class="feature-icon" style="--tint: var(--cyan)">🔄</div>
          <h3>Sync con mobile</h3>
          <p>Voti, riassunti, materie e calendario si sincronizzano tra desktop, iOS e Android.</p>
        </article>
        <article class="card feature">
          <div class="feature-icon" style="--tint: var(--pink)">⚡</div>
          <h3>Aggiornamenti automatici</h3>
          <p>L'app si aggiorna da sola all'avvio. Nessun click, nessuna interruzione del tuo lavoro.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section requirements">
    <div class="container">
      <div class="req-card">
        <h3>Requisiti minimi</h3>
        <div class="req-grid">
          <div>
            <h4>Windows</h4>
            <ul>
              <li>Windows 10 o superiore (64-bit)</li>
              <li>~200 MB spazio disco</li>
              <li>Connessione Internet</li>
            </ul>
          </div>
          <div>
            <h4>macOS</h4>
            <ul>
              <li>macOS 11 Big Sur o superiore</li>
              <li>Intel o Apple Silicon</li>
              <li>~200 MB spazio disco</li>
              <li>Connessione Internet</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .desktop-hero {
      padding: 100px 24px 40px;
      text-align: center;
      background:
        radial-gradient(ellipse at 50% 20%, rgba(168, 85, 247, 0.18), transparent 55%),
        radial-gradient(ellipse at 50% 80%, rgba(6, 182, 212, 0.1), transparent 60%);
    }
    .hero-title {
      font-size: clamp(34px, 5vw, 56px);
      font-weight: 900;
      line-height: 1.1;
      letter-spacing: -1.5px;
      margin-bottom: 20px;
    }
    .hero-lead {
      color: var(--text-sub);
      font-size: 18px;
      max-width: 620px;
      margin: 0 auto 40px;
    }

    /* Download CTA styles (per React Island) */
    :global(.desktop-cta) {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 16px;
    }
    :global(.desktop-cta .btn-mega) {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      padding: 20px 40px;
      border-radius: 20px;
      background: linear-gradient(135deg, var(--purple), var(--pink));
      color: #fff;
      font-weight: 800;
      box-shadow: 0 20px 60px rgba(168, 85, 247, 0.45);
      text-decoration: none;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
      min-width: 320px;
    }
    :global(.desktop-cta .btn-mega:hover) {
      transform: translateY(-2px);
      box-shadow: 0 24px 72px rgba(168, 85, 247, 0.6);
    }
    :global(.btn-mega-title) {
      font-size: 20px;
      letter-spacing: -0.3px;
    }
    :global(.btn-mega-sub) {
      font-size: 12.5px;
      opacity: 0.85;
      margin-top: 4px;
      font-weight: 600;
      letter-spacing: 0.4px;
    }
    :global(.cta-meta) {
      color: var(--text-sub);
      font-size: 13.5px;
    }
    :global(.cta-alt) {
      display: flex;
      gap: 20px;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 4px;
    }
    :global(.cta-alt a) {
      color: var(--text-sub);
      font-size: 13px;
      text-decoration: underline;
      text-decoration-color: rgba(255, 255, 255, 0.2);
      text-underline-offset: 3px;
      transition: color 0.15s ease;
    }
    :global(.cta-alt a:hover) { color: var(--purple); }

    :global(.cta-loading) {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      padding: 32px 0;
      color: var(--text-sub);
    }
    :global(.spinner) {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: 4px solid rgba(168, 85, 247, 0.2);
      border-top-color: var(--purple);
      animation: spin 800ms linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Features + Requirements */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    @media (max-width: 800px) { .features-grid { grid-template-columns: 1fr; } }
    .feature-icon {
      width: 56px; height: 56px;
      display: flex; align-items: center; justify-content: center;
      background: color-mix(in srgb, var(--tint), transparent 82%);
      border: 1px solid color-mix(in srgb, var(--tint), transparent 60%);
      border-radius: 16px;
      font-size: 26px;
      margin-bottom: 16px;
    }
    .feature h3 { font-size: 19px; font-weight: 800; margin-bottom: 8px; letter-spacing: -0.3px; }
    .feature p { color: var(--text-sub); font-size: 15px; line-height: 1.55; }

    .requirements { padding-bottom: 100px; }
    .req-card {
      background: var(--bg-glass);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-xl);
      padding: 40px;
      max-width: 800px;
      margin: 0 auto;
    }
    .req-card h3 { font-size: 22px; font-weight: 800; margin-bottom: 24px; }
    .req-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
    @media (max-width: 600px) { .req-grid { grid-template-columns: 1fr; } }
    .req-grid h4 {
      color: var(--purple);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 1.4px;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .req-grid ul {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 8px;
      color: var(--text-sub);
      font-size: 14.5px;
      line-height: 1.5;
    }
    .req-grid li::before {
      content: "• ";
      color: var(--purple);
      font-weight: 900;
      margin-right: 6px;
    }
  </style>
</BaseLayout>
